# Server
APP_PORT=8080
APP_ENV=development

# PostgreSQL - port 5433 (PostgreSQL cài trực tiếp trên máy)
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=1234
DB_NAME=population_db
DB_SSLMODE=disable

# Encryption Key (AES-256-GCM - 32 bytes base64)
ENCRYPTION_KEY=YWJjZGVmZ2hpamtsbW5vcHFyc3R1dnd4eXoxMjM0NTY=

# JWT Secrets - dùng 2 secret KHÁC NHAU, đủ dài và ngẫu nhiên
# Sinh bằng: openssl rand -base64 48
JWT_ACCESS_SECRET=your-super-secret-access-key-256bit
JWT_REFRESH_SECRET=your-super-secret-refresh-key-256bit

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_ENABLED=true