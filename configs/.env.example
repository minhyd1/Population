# Application
APP_ENV=development
APP_PORT=8080
APP_HOST=0.0.0.0
# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=population_db
DB_SSLMODE=disable
# JWT
JWT_SECRET=change-me-in-production

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Để trống nếu Redis không bật xác thực

REDIS_PASSWORD=

REDIS_DB=0

# Encryption
# AES-256 cần key dài 32 ký tự

ENCRYPTION_KEY=0123456789abcdef0123456789abcdef