# Server
APP_PORT=8080
APP_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=population_db
DB_SSLMODE=disable

# Encryption - AES-256 key (32 bytes, base64 encoded)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your-32-byte-base64-encoded-key-here==

# JWT (optional - for future auth)
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRE_HOURS=24
